{
  "type": "module",
  "name": "@yamitzky/freee",
  "version": "0.13.0",
  "bin": {
    "freee": "./bin/freee.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run build.ts",
    "start": "bun run src/cli-app/entry.ts",
    "dev": "bun --watch run src/cli-app/entry.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "knip": "knip",
    "format": "biome format --write src/",
    "check": "biome check src/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "generate:references": "bun run scripts/generate-references.ts",
    "fetch:schemas": "bun run scripts/fetch-schemas.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "author": "freee_jp",
  "license": "Apache-2.0",
  "description": "freee API CLI & Agent Skill",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^24.10.1",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "knip": "^5.78.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "open": "^10.2.0",
    "prompts": "^2.4.2",
    "zod": "^3.25.76"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "freee",
    "api",
    "accounting",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yamitzky/freee-mcp.git"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md"
  ],
  "packageManager": "bun@1.3.10"
}
